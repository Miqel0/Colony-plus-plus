{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Mars Colony",
            "type": "shell",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/std:c++17",
                "/Fe:${workspaceFolder}\\build\\mars.exe",
                "/Fo:${workspaceFolder}\\build\\",
                "${workspaceFolder}\\src\\*.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"],
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "detail": "Kompilacja MSVC do folderu build"
        }
    ]
}